<IfModule mod_rewrite.c>
    RewriteEngine On
    # Change to '' if app is at domain root, or e.g. /restaurant-system/
    RewriteBase /restaurant-system/

    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    RewriteRule ^(.*)$ index.php?route=$1 [QSA,L]
</IfModule>
