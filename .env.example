# Velvet Plate Production Environment Template
# Copy this to .env on your server (if using a library) 
# OR use these values for your shared hosting control panel

DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password

APP_ENV=production
APP_DEBUG=false
APP_URL=https://yourdomain.com
BASE_URL=
